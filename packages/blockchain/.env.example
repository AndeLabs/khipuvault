# Database URL (required)
DATABASE_URL="postgresql://user:password@localhost:5432/khipuvault?schema=public"

# Network Configuration
# Set to "testnet" or "mainnet" - defaults to testnet
NETWORK=testnet

# Blockchain RPC URL (optional, defaults to network's primary RPC)
# Override only if you need a specific RPC endpoint
RPC_URL="https://rpc.test.mezo.org"

# Contract addresses (DEPRECATED - now managed in packages/web3/src/addresses/)
# These are kept for legacy compatibility only
INDIVIDUAL_POOL_ADDRESS="0xdfBEd2D3efBD2071fD407bF169b5e5533eA90393"
COOPERATIVE_POOL_ADDRESS="0x323FcA9b377fe29B8fc95dDbD9Fe54cea1655F88"

# Reorg Detection Configuration
# Number of confirmations before considering a block final (default: 6)
# Mezo testnet: 6 blocks = ~1 minute with 10s block time
REORG_CONFIRMATION_DEPTH=6

# How often to check for reorgs in milliseconds (default: 30000 = 30s)
REORG_CHECK_INTERVAL=30000

# Number of recent block hashes to keep for detection (default: 100)
# Larger depth = more memory but can detect deeper reorgs
REORG_DETECTION_DEPTH=100

# Maximum reorg depth to handle automatically (default: 50)
# Deeper reorgs will be logged but require manual intervention
REORG_MAX_DEPTH=50
