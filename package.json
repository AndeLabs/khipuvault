{
  "name": "khipu-vault",
  "version": "3.0.0",
  "private": true,
  "description": "Bitcoin savings platform on Mezo - Complete monorepo",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@khipu/web",
    "dev:api": "turbo run dev --filter=@khipu/api",
    "dev:indexer": "turbo run dev --filter=@khipu/blockchain",
    "dev:docs": "turbo run dev --filter=@khipu/docs",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@khipu/web",
    "build:api": "turbo run build --filter=@khipu/api",
    "build:docs": "turbo run build --filter=@khipu/docs",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "./scripts/clean.sh",
    "setup": "./scripts/setup.sh",
    "db:generate": "pnpm --filter @khipu/database db:generate",
    "db:push": "pnpm --filter @khipu/database db:push",
    "db:migrate": "pnpm --filter @khipu/database db:migrate",
    "db:studio": "pnpm --filter @khipu/database db:studio",
    "db:seed": "pnpm --filter @khipu/database db:seed",
    "contracts:build": "cd packages/contracts && forge build",
    "contracts:test": "cd packages/contracts && forge test",
    "contracts:deploy": "cd packages/contracts && forge script script/Deploy.s.sol",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "security:setup": "cd security/shannon && ./run-shannon.sh setup",
    "security:scan": "cd security/shannon && ./run-shannon.sh quick",
    "security:scan:full": "cd security/shannon && ./run-shannon.sh full",
    "security:snyk:test": "snyk test --all-projects",
    "security:snyk:code": "snyk code test",
    "security:snyk:monitor": "snyk monitor --all-projects",
    "security:semgrep": "semgrep --config auto .",
    "security:semgrep:custom": "semgrep --config .semgrep.yml .",
    "security:semgrep:ci": "semgrep --config auto --error --json --output semgrep-report.json .",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:check": "pnpm run security:audit && pnpm run security:snyk:test",
    "license:check": "./scripts/check-licenses.sh",
    "license:report": "npx license-checker --json --out license-report.json",
    "license:report:csv": "npx license-checker --csv --out license-report.csv",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "commit:help": "cat .husky/COMMIT_CONVENTION.md",
    "push:check": "pnpm typecheck && pnpm test -- --run",
    "push:help": "cat .husky/PRE_PUSH_GUIDE.md",
    "prepare": "husky",
    "spell:check": "cspell \"{apps,packages}/**/*.{ts,tsx,js,jsx,md,sol}\" \"*.md\"",
    "spell:check:changed": "cspell --gitignore $(git diff --name-only --cached --diff-filter=d)"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@microsoft/eslint-plugin-sdl": "^1.1.0",
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "cspell": "^9.7.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^3.0.1",
    "headless-web3-provider": "^0.3.2",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.0",
    "prettier": "^3.1.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "snyk": "^1.1303.2",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "valibot": ">=1.2.0",
      "node-forge": ">=1.3.2",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@trpc/server": ">=10.45.3",
      "h3": ">=1.15.5",
      "hono": ">=4.11.7",
      "jws": ">=4.0.1",
      "preact": ">=10.27.3",
      "qs": ">=6.14.1",
      "fast-xml-parser": ">=5.3.4",
      "body-parser": ">=2.2.2",
      "lodash": ">=4.17.23",
      "@sentry/webpack-plugin": ">=4.9.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "react": "^19.2.0",
      "react-dom": "^19.2.0",
      "next": "15.5.12",
      "axios": ">=1.13.5",
      "elliptic": ">=6.6.1"
    },
    "patchedDependencies": {
      "fumadocs-core@17.0.0": "patches/fumadocs-core@17.0.0.patch",
      "fumadocs-ui@17.0.0": "patches/fumadocs-ui@17.0.0.patch",
      "@fumadocs/ui@17.0.0": "patches/@fumadocs__ui@17.0.0.patch"
    }
  },
  "dependencies": {
    "web-vitals": "^5.2.0"
  }
}
